<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Base App Theme ─────────────────────────────────────────────────── -->
    <style name="Theme.BrainZone" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/purple_700</item>
        <item name="android:windowBackground">@color/background_color</item>
    </style>

    <!-- ── Splash Theme ───────────────────────────────────────────────────── -->
    <style name="Theme.BrainZone.Splash" parent="Theme.BrainZone">
        <item name="android:windowBackground">@color/purple_500</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- ── Button Styles ──────────────────────────────────────────────────── -->
    <style name="BrainZoneButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/purple_500</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="BrainZoneButtonOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/purple_500</item>
        <item name="android:textColor">@color/purple_500</item>
        <item name="cornerRadius">12dp</item>
    </style>

</resources>