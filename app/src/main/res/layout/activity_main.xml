<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome!"
            android:textSize="36sp"
            android:textColor="@color/primary_text"
            android:fontFamily="sans-serif-black"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/tvHighScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Best Score: 0"
            android:textSize="18sp"
            android:textColor="@color/secondary_text"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp"/>

        <!-- Math Puzzle Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGame1"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/math_tile_color"
            android:clickable="true"
            android:focusable="true">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Math\nPuzzle"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/white"
                    android:contentDescription="Math Icon"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Memory Match Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGame2"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/memory_tile_color"
            android:clickable="true"
            android:focusable="true">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memory\nMatch"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/white"
                    android:contentDescription="Memory Icon"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Word Scramble Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGame3"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginBottom="40dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/word_tile_color"
            android:clickable="true"
            android:focusable="true">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Word\nScramble"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_sort_alphabetically"
                    app:tint="@color/white"
                    android:contentDescription="Word Icon"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeaderboard"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="Leaderboard"
                android:textSize="16sp"
                android:textColor="@color/purple_500"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconTint="@color/purple_500"
                app:iconSize="24dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="Settings"
                android:textSize="16sp"
                android:textColor="@color/purple_500"
                app:icon="@android:drawable/ic_menu_preferences"
                app:iconTint="@color/purple_500"
                app:iconSize="24dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>